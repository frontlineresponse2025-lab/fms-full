# ── Discord OAuth ──────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# ── Discord Bot (for guild member lookup + role sync) ──────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Discord Role IDs (right-click role in Discord → Copy Role ID) ──────────
DISCORD_ROLE_ADMIN_ID=
DISCORD_ROLE_SUPERVISOR_ID=
DISCORD_ROLE_OFFICER_ID=
DISCORD_ROLE_RECRUIT_ID=

# ── App ────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string
ALLOWED_ORIGIN=https://yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fms
