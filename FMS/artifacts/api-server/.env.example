# PostgreSQL connection string from Neon (or any Postgres provider)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the server listens on (Railway sets this automatically)
PORT=8080

# Your Cloudflare Pages URL or custom frontend domain
# This tells the API which origin is allowed to make requests
ALLOWED_ORIGIN=https://fms.frontlineresponse.com
